{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "name": "@vbudovski/rollup-plugin-transform-regex",
  "license": "MIT",
  "version": "0.1.2",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "@commitlint/config-conventional": "npm:@commitlint/config-conventional@^20.5.0",
    "@commitlint/types": "npm:@commitlint/types@^20.5.0",
    "@rollup/pluginutils": "npm:@rollup/pluginutils@^5.3.0",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.17/bdd",
    "@types/estree": "npm:@types/estree@^1.0.8",
    "estree": "npm:@types/estree@^1.0.8",
    "acorn": "npm:acorn@^8.16.0",
    "estree-walker": "npm:estree-walker@^3.0.3",
    "magic-string": "npm:magic-string@^0.30.21",
    "regex": "npm:regex@^6.1.0",
    "regexp-tree": "npm:regexp-tree@^0.1.27",
    "rollup": "npm:rollup@^4.60.1"
  },
  "tasks": {
    "init": "deno run --allow-env --allow-read --allow-write --allow-run npm:husky",
    "lint-staged": "deno run --allow-env --allow-read --allow-write --allow-sys --allow-run npm:lint-staged",
    "ci": "deno run --allow-env --allow-read --allow-run npm:@biomejs/biome ci",
    "check": "deno run --allow-env --allow-read --allow-run npm:@biomejs/biome check",
    "commitlint": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run npm:@commitlint/cli"
  },
  "nodeModulesDir": "auto",
  "publish": {
    "include": ["src", "LICENSE.md", "README.md"]
  }
}
